
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .

<https://example.com/ont/cargobike> a owl:Ontology ;
  owl:imports <https://example.com/ont/cargobike/catalog> ;
  owl:imports <https://example.com/ont/cargobike/customers> ;
  owl:imports <https://example.com/ont/cargobike/inventory> ;
  owl:imports <https://example.com/ont/cargobike/orders> ;
  owl:imports <https://example.com/ont/cargobike/shipping> ;
  rdfs:label "Cargo Bike Ontology" ;
  rdfs:comment "Top-level ontology importing all domain-specific sub-ontologies." .